# ============================================
# RankedEDHK Environment Variables Template
# ============================================
# Copy this file to .env.local and fill in with your actual credentials
# IMPORTANT: Never commit .env.local to GitHub - it's in .gitignore

# ============================================
# SUPABASE (Database & Auth)
# ============================================
# Get from Supabase Project → Settings → API
# Project: RankedEDHKLOG
NEXT_PUBLIC_SUPABASE_URL=https://[your-project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...

# ============================================
# GOOGLE GEMINI API (Content Moderation)
# ============================================
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=...

# ============================================
# BETTER-AUTH (Authentication)
# ============================================
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=abc123def456...
BETTER_AUTH_URL=http://localhost:3000

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development

# ============================================
# PRODUCTION ONLY
# ============================================
# Set these only in Vercel Environment Variables dashboard
# - SUPABASE_SERVICE_ROLE_KEY (mark as "Production Only")
# - CRON_SECRET=xyz789...
# - BETTER_AUTH_URL=https://yourdomain.vercel.app (after deployment)
# - NODE_ENV=production
