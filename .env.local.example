# ============================================
# SUPABASE (Database & Auth)
# ============================================
# Get from Supabase Project → Settings → API
# Project: RankedEDHKLOG
NEXT_PUBLIC_SUPABASE_URL=https://[your-project].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================
# BETTER-AUTH (Authentication)
# ============================================
# Generate secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=abc123def456...
BETTER_AUTH_URL=http://localhost:3000

# ============================================
# GOOGLE GEMINI API (Content Moderation)
# ============================================
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyD...

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development

# ============================================
# NOTES
# ============================================
# - Never commit actual credentials to .env.local.example
# - Copy this to .env.local and fill in your actual values
# - For production: Set SUPABASE_SERVICE_ROLE_KEY as "Production Only" in Vercel
# - Update BETTER_AUTH_URL after Vercel deployment
